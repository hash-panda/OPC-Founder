---
import Layout from '../../layouts/Layout.astro';

const articles = [
  {
    slug: 'why-opc',
    title: '为什么选择一人公司？',
    date: '2026-03-01',
    excerpt: '从大厂离职后，我开始思考：一个人能做什么？答案是——很多。',
    tags: ['思考', '创业']
  },
  {
    slug: 'ai-agent-exploration',
    title: 'AI Agent 探索之路',
    date: '2026-03-15',
    excerpt: '从想法到实现，记录我开发 OpenClaw AI Agent 的过程。',
    tags: ['AI', 'Agent', '技术']
  },
  {
    slug: 'first-product',
    title: '第一个产品的诞生',
    date: '2026-04-01',
    excerpt: '从0到1是最难的，但也是最值得的。',
    tags: ['产品', '开发']
  }
];

function formatDate(dateStr: string) {
  const date = new Date(dateStr);
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title="文章 - OPC Founder">
  <section class="py-20 pt-28 bg-slate-950 min-h-screen">
    <div class="container mx-auto px-6">
      <div class="max-w-3xl mx-auto">
        <!-- Header -->
        <div class="mb-12">
          <h1 class="text-3xl font-bold text-white mb-2">文章</h1>
          <p class="text-slate-500">记录创业心得、技术探索与生活感悟</p>
        </div>

        <!-- Articles List -->
        <div class="space-y-6">
          {articles.map((article) => (
            <a
              href={`/blog/${article.slug}`}
              class="block group p-6 bg-slate-900/50 rounded-xl border border-slate-800 hover:border-slate-700 transition-all"
            >
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
                <div class="flex-1">
                  <h2 class="text-lg font-semibold text-white group-hover:text-orange-400 transition-colors mb-2">
                    {article.title}
                  </h2>
                  <p class="text-slate-400 text-sm leading-relaxed">
                    {article.excerpt}
                  </p>
                  <div class="flex gap-3 mt-3">
                    {article.tags.map((tag) => (
                      <span class="text-xs text-slate-600">#{tag}</span>
                    ))}
                  </div>
                </div>
                <div class="text-slate-600 text-sm whitespace-nowrap flex items-center gap-2">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                  </svg>
                  {formatDate(article.date)}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
