---
import Layout from '../../layouts/Layout.astro';

const articles = [
  {
    slug: 'why-opc',
    title: '为什么选择一人公司？',
    date: '2026-03-01',
    excerpt: 'AI的火热，让我开始思考：一个人能做什么？答案是——很多。',
    tags: ['思考', '创业'],
    readTime: '5 分钟'
  },
  {
    slug: 'ai-agent-exploration',
    title: 'AI Agent 探索之路',
    date: '2026-03-09',
    excerpt: '从想法到实现，记录我开发 OpenClaw AI Agent 的过程。',
    tags: ['AI', 'Agent', '技术'],
    readTime: '8 分钟'
  },
  {
    slug: 'first-product',
    title: '第一个产品的诞生',
    date: '2026-03-05',
    excerpt: '从0到1是最难的，但也是最值得的。',
    tags: ['产品', '开发'],
    readTime: '6 分钟'
  }
];

function formatDate(dateStr: string) {
  const date = new Date(dateStr);
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title="文章 - OPC Founder">
  <section class="py-20 pt-28 min-h-screen bg-[#0a0a0a]">
    <div class="container mx-auto px-6">
      <div class="max-w-3xl mx-auto">
        <!-- Header -->
        <div class="mb-12 animate-on-scroll">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-[2px] bg-teal-500"></div>
            <span class="text-teal-400 text-sm font-medium uppercase tracking-wider">Blog</span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">文章</h1>
          <p class="text-white/70 text-lg">记录创业心得、技术探索与生活感悟</p>
        </div>

        <!-- Articles List -->
        <div class="space-y-6">
          {articles.map((article, index) => (
            <div
              class="group p-8 bg-[#111111] rounded-2xl border border-[#2a2a2a] hover:border-teal-500/30 transition-all duration-300 card-hover animate-on-scroll"
              style={`animation-delay: ${index * 100}ms`}
            >
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
                <div class="flex-1">
                  <!-- Meta -->
                  <div class="flex items-center gap-4 mb-3">
                    <span class="flex items-center gap-2 text-white/60 text-sm">
                      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2"/>
                        <line x1="16" y1="2" x2="16" y2="6"/>
                        <line x1="8" y1="2" x2="8" y2="6"/>
                        <line x1="3" y1="10" x2="21" y2="10"/>
                      </svg>
                      {formatDate(article.date)}
                    </span>
                    <span class="flex items-center gap-2 text-white/60 text-sm">
                      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12,6 12,12 16,14"/>
                      </svg>
                      {article.readTime}
                    </span>
                  </div>

                  <!-- Title -->
                  <h2 class="text-xl font-bold text-white mb-3 group-hover:text-teal-400 transition-colors">
                    {article.title}
                  </h2>

                  <!-- Excerpt -->
                  <p class="text-white/70 text-sm leading-relaxed mb-4">
                    {article.excerpt}
                  </p>

                  <!-- Tags -->
                  <div class="flex gap-2">
                    {article.tags.map((tag) => (
                      <span class="px-3 py-1 text-xs text-white/60 bg-white/5 rounded-full group-hover:bg-teal-500/10 group-hover:text-teal-400/70 transition-colors">
                        #{tag}
                      </span>
                    ))}
                  </div>
                </div>

                <!-- Arrow -->
                <div class="hidden md:flex items-center text-teal-400/40 group-hover:text-teal-400 transition-colors">
                  <svg class="w-6 h-6 group-hover:translate-x-2 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Coming Soon Notice -->
        <div class="mt-12 p-6 bg-teal-500/10 border border-teal-500/20 rounded-2xl text-center animate-on-scroll">
          <p class="text-teal-400 text-sm">
            文章即将上线，敬请期待...
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
