---
// Skills & Services section

const skills = [
  { name: 'AI Agent 开发', level: 90 },
  { name: '全栈开发', level: 85 },
  { name: '产品设计', level: 75 },
  { name: '内容创作', level: 80 },
  { name: '项目管理', level: 85 },
];

const services = [
  {
    title: 'AI Agent 开发',
    description: '基于大语言模型构建智能 Agent，自动化业务流程，提升效率。',
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
    </svg>`,
    available: true
  },
  {
    title: '技术咨询',
    description: '提供技术架构设计、团队技术选型、产品技术方案等咨询服务。',
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>`,
    available: true
  },
  {
    title: '内容合作',
    description: '技术文章撰写、产品评测、创业经验分享等内容合作。',
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
    </svg>`,
    available: false
  }
];

const techStack = [
  'TypeScript', 'Python', 'React', 'Next.js', 'Node.js',
  'LangChain', 'OpenAI', 'Claude', 'PostgreSQL', 'Redis',
  'Docker', 'AWS', 'Vercel', 'Git'
];
---

<section id="skills" class="py-24 bg-[#111111]">
  <div class="container mx-auto px-6">
    <!-- Section Header -->
    <div class="max-w-3xl mx-auto mb-16 animate-on-scroll">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-12 h-[2px] bg-teal-500"></div>
        <span class="text-teal-400 text-sm font-medium uppercase tracking-wider">Skills & Services</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">技能与服务</h2>
      <p class="text-white/60 text-lg">我能提供的价值</p>
    </div>

    <div class="max-w-6xl mx-auto">
      <!-- Services Cards -->
      <div class="grid md:grid-cols-3 gap-6 mb-16">
        {services.map((service, index) => (
          <div class="group p-6 bg-[#0a0a0a] rounded-2xl border border-[#2a2a2a] card-hover animate-on-scroll" style={`animation-delay: ${index * 100}ms`}>
            <div class="flex items-start justify-between mb-4">
              <div class="p-3 bg-teal-500/10 rounded-xl text-teal-400 group-hover:bg-teal-500/20 transition-colors">
                <Fragment set:html={service.icon} />
              </div>
              {service.available ? (
                <span class="flex items-center gap-1.5 text-xs text-teal-400">
                  <span class="w-2 h-2 bg-teal-400 rounded-full animate-pulse"></span>
                  可预约
                </span>
              ) : (
                <span class="text-xs text-white/30">暂不可用</span>
              )}
            </div>
            <h3 class="text-lg font-bold text-white mb-2 group-hover:text-teal-400 transition-colors">{service.title}</h3>
            <p class="text-white/60 text-sm leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>

      <!-- Skills & Tech Stack -->
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Skills Progress -->
        <div class="p-8 bg-[#0a0a0a] rounded-2xl border border-[#2a2a2a] animate-on-scroll">
          <h3 class="text-xl font-bold text-white mb-6">核心技能</h3>
          <div class="space-y-5">
            {skills.map((skill) => (
              <div>
                <div class="flex justify-between mb-2">
                  <span class="text-white/70 text-sm">{skill.name}</span>
                  <span class="text-teal-400 text-sm font-medium">{skill.level}%</span>
                </div>
                <div class="h-2 bg-[#2a2a2a] rounded-full overflow-hidden">
                  <div class="h-full bg-gradient-to-r from-teal-500 to-teal-400 rounded-full transition-all duration-1000" style={`width: ${skill.level}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Tech Stack -->
        <div class="p-8 bg-[#0a0a0a] rounded-2xl border border-[#2a2a2a] animate-on-scroll" style="animation-delay: 100ms">
          <h3 class="text-xl font-bold text-white mb-6">技术栈</h3>
          <div class="flex flex-wrap gap-2">
            {techStack.map((tech) => (
              <span class="px-4 py-2 text-sm text-white/60 bg-[#1a1a1a] rounded-lg border border-[#2a2a2a] hover:border-teal-500/50 hover:text-teal-400 transition-all cursor-default">
                {tech}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
