---
// Timeline section - Animated vertical timeline

const milestones = [
  { date: '2026.03', title: '启程', description: '注册 opcfounder.com，开始探索一人公司', status: 'completed' },
  { date: '2026.03', title: 'OpenClaw 启动', description: '开始 AI Agent 项目研发', status: 'completed' },
  { date: '2026.03', title: '自媒体运营', description: '开始分享创业经验', status: 'current' },
  { date: '规划中', title: '产品开发', description: '开发独立产品服务用户', status: 'upcoming' },
  { date: '未来', title: '持续探索', description: '更多可能性等待发现...', status: 'upcoming' }
];

const statusStyles = {
  completed: { dot: 'bg-teal-400', ring: 'border-teal-400', glow: 'shadow-teal-400/30' },
  current: { dot: 'bg-teal-400 animate-pulse', ring: 'border-teal-400', glow: 'shadow-teal-400/50 shadow-lg' },
  upcoming: { dot: 'bg-[#2a2a2a]', ring: 'border-[#2a2a2a]', glow: '' }
};
---

<section class="py-24 bg-[#111111]">
  <div class="container mx-auto px-6">
    <!-- Section Header -->
    <div class="max-w-3xl mx-auto mb-16 animate-on-scroll">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-12 h-[2px] bg-teal-500"></div>
        <span class="text-teal-400 text-sm font-medium uppercase tracking-wider">Timeline</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">成长轨迹</h2>
      <p class="text-white/70 text-lg">记录每一步</p>
    </div>

    <!-- Timeline -->
    <div class="max-w-3xl mx-auto">
      <div class="relative">
        <!-- Vertical Line -->
        <div class="absolute left-[23px] top-0 bottom-0 w-[2px] bg-gradient-to-b from-teal-500 via-teal-500/50 to-[#2a2a2a]"></div>

        <!-- Timeline Items -->
        <div class="space-y-8">
          {milestones.map((milestone, index) => (
            <div class="relative pl-16 animate-on-scroll" style={`animation-delay: ${index * 100}ms`}>
              <!-- Dot -->
              <div class={`absolute left-0 top-0 w-12 h-12 rounded-full border-2 ${statusStyles[milestone.status as keyof typeof statusStyles].ring} bg-[#111111] flex items-center justify-center ${statusStyles[milestone.status as keyof typeof statusStyles].glow}`}>
                <div class={`w-4 h-4 rounded-full ${statusStyles[milestone.status as keyof typeof statusStyles].dot}`}></div>
              </div>

              <!-- Content Card -->
              <div class="group p-6 bg-[#0a0a0a] rounded-2xl border border-[#2a2a2a] hover:border-teal-500/30 transition-all duration-300">
                <div class="flex items-center gap-3 mb-2">
                  <span class="px-3 py-1 text-xs font-mono text-teal-400 bg-teal-500/10 rounded-full">{milestone.date}</span>
                  {milestone.status === 'current' && (
                    <span class="flex items-center gap-1 text-xs text-teal-400">
                      <span class="w-1.5 h-1.5 bg-teal-400 rounded-full animate-pulse"></span>
                      现在
                    </span>
                  )}
                </div>
                <h3 class="text-xl font-bold text-white mb-2 group-hover:text-teal-400 transition-colors">{milestone.title}</h3>
                <p class="text-white/70 text-sm leading-relaxed">{milestone.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
