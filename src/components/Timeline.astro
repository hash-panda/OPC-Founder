---
// Timeline section - Minimal horizontal style

const milestones = [
  { date: '2026.03', title: '启程', description: '注册 opcfounder.com，开始探索一人公司' },
  { date: '2026.04', title: 'OpenClaw 启动', description: '开始 AI Agent 项目研发' },
  { date: '2026.05', title: '自媒体运营', description: '开始分享创业经验' },
  { date: '2026.06', title: '产品开发', description: '开发独立产品服务用户' }
];
---

<section class="py-20 bg-slate-900">
  <div class="container mx-auto px-6">
    <div class="max-w-3xl mx-auto">
      <!-- Section Header -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-white mb-2">时间线</h2>
        <p class="text-slate-500">成长的足迹</p>
      </div>

      <!-- Timeline -->
      <div class="relative">
        <!-- Line -->
        <div class="absolute left-3 top-0 bottom-0 w-px bg-slate-700"></div>

        <!-- Items -->
        <div class="space-y-8">
          {milestones.map((milestone, index) => (
            <div class="relative pl-10">
              <!-- Dot -->
              <div class={`absolute left-0 top-1.5 w-6 h-6 rounded-full border-2 flex items-center justify-center ${index === 0 ? 'bg-orange-500 border-orange-500' : 'bg-slate-800 border-slate-600'}`}>
                <div class={`w-2 h-2 rounded-full ${index === 0 ? 'bg-white' : 'bg-slate-500'}`}></div>
              </div>

              <!-- Content -->
              <div>
                <span class="text-xs text-slate-500 font-mono">{milestone.date}</span>
                <h3 class="text-lg font-semibold text-white mt-1">{milestone.title}</h3>
                <p class="text-sm text-slate-400 mt-1">{milestone.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
