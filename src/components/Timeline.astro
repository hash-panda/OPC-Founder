---
const milestones = [
  {
    year: '2023',
    title: '开启一人公司之旅',
    description: '辞去大厂工作，开始独立创业'
  },
  {
    year: '2023',
    title: 'OpenClaw 启动',
    description: '开始龙虾养殖项目，  },
  {
    year: '2024',
    title: '自媒体运营',
    description: '开始在各大平台分享创业经验'
  },
  {
    year: '2024',
    title: '产品开发',
    description: '开发多个独立产品，服务更多用户'
  },
  {
    year: '未来',
    title: '持续探索',
    description: '更多可能性等待探索...'
  }
];
---

<section class="py-20 bg-gray-50">
  <div class="container mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900">创业时间线</h2>
      <p class="text-xl text-gray-600 mt-4">一路走来的里程碑</p>
    </div>

    <div class="max-w-4xl mx-auto">
      <div class="relative">
        <!-- Timeline line -->
        <div class="absolute left-1/2 transform -translate-x-1/2 h-full w-1 bg-orange-200"></div>

        <!-- Milestones -->
        <div class="space-y-12">
          {milestones.map((milestone, index) => (
            <div class={`relative flex items-center ${index % 2 === 0 ? 'justify-start' : 'justify-end'}`}>
              <div class={`w-5/12 ${index % 2 === 0 ? 'text-right pr-8' : 'text-left pl-8'}`}>
                <div class="bg-white p-6 rounded-xl shadow-lg">
                  <span class="text-orange-600 font-bold">{milestone.year}</span>
                  <h3 class="text-xl font-bold text-gray-900 mt-2">{milestone.title}</h3>
                  <p class="text-gray-600 mt-2">{milestone.description}</p>
                </div>
              </div>
              <!-- Dot -->
              <div class="absolute left-1/2 transform -translate-x-1/2 w-4 h-4 bg-orange-600 rounded-full border-4 border-white"></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
