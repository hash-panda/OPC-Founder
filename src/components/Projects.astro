---
// Projects section - Clean list style

const projects = [
  {
    title: 'OpenClaw',
    subtitle: 'AI Agent 智能助手',
    description: '基于大语言模型的智能 Agent，帮助自动化工作流程，提升效率。',
    link: 'https://openclaw.com',
    status: 'active',
    tags: ['AI', 'Agent', '自动化']
  },
  {
    title: '自媒体',
    subtitle: '内容创作与分享',
    description: '在各平台分享创业心得、技术干货，记录一人公司的成长历程。',
    link: '#',
    status: 'active',
    tags: ['内容', '创业']
  },
  {
    title: '产品开发',
    subtitle: '独立 SaaS 项目',
    description: '从想法到上线，用代码解决真实问题，构建有价值的数字产品。',
    link: '#',
    status: 'building',
    tags: ['技术', 'SaaS']
  }
];

const statusConfig = {
  active: { text: '进行中', class: 'bg-green-500/10 text-green-400 border-green-500/20' },
  building: { text: '构建中', class: 'bg-amber-500/10 text-amber-400 border-amber-500/20' }
};
---

<section id="projects" class="py-20 bg-slate-950">
  <div class="container mx-auto px-6">
    <div class="max-w-3xl mx-auto">
      <!-- Section Header -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-white mb-2">项目</h2>
        <p class="text-slate-500">正在做的事情</p>
      </div>

      <!-- Projects List -->
      <div class="space-y-6">
        {projects.map((project) => (
          <a
            href={project.link}
            class="block group p-6 bg-slate-900/50 rounded-xl border border-slate-800 hover:border-slate-700 transition-all"
          >
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <h3 class="text-lg font-semibold text-white group-hover:text-orange-400 transition-colors">
                    {project.title}
                  </h3>
                  <span class={`px-2 py-0.5 text-xs rounded border ${statusConfig[project.status as keyof typeof statusConfig].class}`}>
                    {statusConfig[project.status as keyof typeof statusConfig].text}
                  </span>
                </div>
                <p class="text-slate-500 text-sm mb-2">{project.subtitle}</p>
                <p class="text-slate-400 text-sm leading-relaxed">{project.description}</p>

                <!-- Tags -->
                <div class="flex gap-2 mt-3">
                  {project.tags.map((tag) => (
                    <span class="text-xs text-slate-600">#{tag}</span>
                  ))}
                </div>
              </div>

              <!-- Arrow -->
              <div class="text-slate-600 group-hover:text-orange-500 transition-colors self-end md:self-center">
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
