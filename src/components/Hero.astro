---
---

<section class="min-h-screen flex items-center justify-center bg-gradient-to-br from-orange-50 via-white to-amber-50 pt-20">
  <div class="container mx-auto px-6 py-20">
    <div class="flex flex-col lg:flex-row items-center gap-12">
      <!-- Left Content -->
      <div class="flex-1 text-center lg:text-left">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 leading-tight">
          一个人，也能
          <span class="text-orange-600">改变世界</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-600 mt-6 max-w-2xl">
          记录一人公司创始人的多元探索之旅
        </p>
        <p class="text-gray-500 mt-4 max-w-xl">
          自媒体 · OpenClaw龙虾养殖 · 产品开发 · 更多可能
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mt-8 justify-center lg:justify-start">
          <a href="#projects" class="px-8 py-4 bg-orange-600 text-white rounded-lg font-semibold hover:bg-orange-700 transition-colors shadow-lg shadow-orange-200">
            探索我的项目
          </a>
          <a href="#about" class="px-8 py-4 border-2 border-gray-300 text-gray-700 rounded-lg font-semibold hover:border-orange-600 hover:text-orange-600 transition-colors">
            了解更多
          </a>
        </div>
      </div>

      <!-- Right Content - Avatar/Visual -->
      <div class="flex-1 flex justify-center">
        <div class="relative">
          <div class="w-64 h-64 md:w-80 md:h-80 rounded-full bg-gradient-to-br from-orange-400 to-amber-500 flex items-center justify-center shadow-2xl">
            <span class="text-8xl md:text-9xl">🚀</span>
          </div>
          <!-- Floating badges -->
          <div class="absolute -top-4 -right-4 bg-white rounded-full px-4 py-2 shadow-lg animate-bounce">
            <span class="text-2xl">🦞</span>
          </div>
          <div class="absolute -bottom-4 -left-4 bg-white rounded-full px-4 py-2 shadow-lg">
            <span class="text-2xl">💻</span>
          </div>
          <div class="absolute top-1/2 -right-8 bg-white rounded-full px-4 py-2 shadow-lg">
            <span class="text-2xl">📱</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
