---
// Hero section - Clean minimal design
---

<section class="min-h-[70vh] flex items-center bg-slate-950 pt-16">
  <div class="container mx-auto px-6">
    <div class="max-w-3xl">
      <!-- Tagline -->
      <p class="text-orange-500 text-sm font-medium tracking-wider uppercase mb-4">
        One Person Company
      </p>

      <!-- Main Title -->
      <h1 class="text-4xl md:text-6xl font-bold text-white leading-tight mb-6">
        一个人的<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-amber-500">多元探索</span>
      </h1>

      <!-- Description -->
      <p class="text-lg text-slate-400 leading-relaxed mb-8 max-w-xl">
        用 AI Agent 构建产品，用内容记录成长，用代码解决问题。
        这是关于一个人如何做很多事情的故事。
      </p>

      <!-- CTA -->
      <div class="flex flex-wrap gap-4">
        <a href="#projects" class="px-6 py-3 bg-orange-500 text-white font-medium rounded-lg hover:bg-orange-600 transition-colors">
          查看项目
        </a>
        <a href="/blog" class="px-6 py-3 bg-slate-800 text-white font-medium rounded-lg hover:bg-orange-500 transition-colors">
          阅读文章
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Brief intro strip -->
<section class="bg-slate-900 py-12 border-y border-slate-800">
  <div class="container mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-8 text-center md:text-left">
      <div>
        <div class="text-3xl font-bold text-orange-500 mb-1">OpenClaw</div>
        <div class="text-slate-500 text-sm">AI Agent 项目</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-white mb-1">自媒体</div>
        <div class="text-slate-500 text-sm">内容创作与分享</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-white mb-1">产品开发</div>
        <div class="text-slate-500 text-sm">独立开发 SaaS</div>
      </div>
    </div>
  </div>
</section>
