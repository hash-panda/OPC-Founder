---
// Hero section - Dynamic creative design with 3D visual
const roles = ['AI Agent 构建者', '内容创作者', '产品开发者', '独立创业者'];
---

<section class="min-h-screen flex items-center relative overflow-hidden pt-16">
  <!-- Background Effects -->
  <div class="absolute inset-0 bg-[#0a0a0a]">
    <!-- Gradient orbs -->
    <div class="absolute top-1/4 -left-32 w-96 h-96 bg-teal-500/10 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-teal-400/5 rounded-full blur-3xl animate-float" style="animation-delay: -3s;"></div>
    <!-- Grid pattern -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(20,184,166,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(20,184,166,0.03)_1px,transparent_1px)] bg-[size:64px_64px]"></div>
  </div>

  <!-- 3D Canvas Container -->
  <div id="hero-3d-container" class="hidden lg:block absolute right-0 top-0 w-1/2 h-full pointer-events-auto"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-4xl">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-teal-500/10 border border-teal-500/20 rounded-full mb-8 animate-fade-in-up">
        <span class="w-2 h-2 bg-teal-400 rounded-full animate-pulse"></span>
        <span class="text-teal-400 text-sm font-medium">One Person Company</span>
      </div>

      <!-- Main Title -->
      <h1 class="text-5xl md:text-7xl font-bold leading-tight mb-6 animate-fade-in-up delay-100">
        <span class="text-white">一个人的</span>
        <br/>
        <span class="gradient-text">多元探索</span>
      </h1>

      <!-- Typewriter Effect -->
      <div class="flex items-center gap-3 mb-8 animate-fade-in-up delay-200">
        <span class="text-white/60 text-lg">我是</span>
        <span id="typewriter" class="text-teal-400 text-lg font-medium"></span>
        <span class="w-0.5 h-6 bg-teal-400 animate-pulse"></span>
      </div>

      <!-- Description -->
      <p class="text-lg md:text-xl text-white/60 leading-relaxed mb-10 max-w-2xl animate-fade-in-up delay-300">
        用 <span class="text-teal-400">AI Agent</span> 构建产品，用内容记录成长，用代码解决问题。
        <br class="hidden md:block"/>
        这是关于一个人如何做很多事情的故事。
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-wrap gap-4 animate-fade-in-up delay-400">
        <a href="/#projects" class="group px-8 py-4 bg-teal-500 text-white font-semibold rounded-xl hover:bg-teal-400 transition-all duration-300 hover:shadow-lg hover:shadow-teal-500/25 flex items-center gap-2">
          查看项目
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="/blog" class="px-8 py-4 bg-white/5 text-white font-semibold rounded-xl border border-white/10 hover:border-teal-500/50 hover:bg-teal-500/10 transition-all duration-300">
          阅读文章
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <div class="w-6 h-10 border-2 border-white/20 rounded-full flex justify-center pt-2">
      <div class="w-1.5 h-3 bg-teal-400 rounded-full animate-pulse"></div>
    </div>
  </div>
</section>

<!-- Stats Strip -->
<section class="py-16 bg-[#111111] border-y border-[#2a2a2a]/50">
  <div class="container mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div class="text-center group">
        <div class="text-3xl md:text-4xl font-bold text-white mb-2 group-hover:text-teal-400 transition-colors">OpenClaw</div>
        <div class="text-white/50 text-sm">AI Agent 项目</div>
      </div>
      <div class="text-center group">
        <div class="text-3xl md:text-4xl font-bold text-white mb-2 group-hover:text-teal-400 transition-colors">3+</div>
        <div class="text-white/50 text-sm">进行中的项目</div>
      </div>
      <div class="text-center group">
        <div class="text-3xl md:text-4xl font-bold text-white mb-2 group-hover:text-teal-400 transition-colors">2026</div>
        <div class="text-white/50 text-sm">启程年份</div>
      </div>
      <div class="text-center group">
        <div class="text-3xl md:text-4xl font-bold text-white mb-2 group-hover:text-teal-400 transition-colors">独立</div>
        <div class="text-white/50 text-sm">一人公司模式</div>
      </div>
    </div>
  </div>
</section>

<script>
  // Typewriter effect
  const roles = ['AI Agent 构建者', '内容创作者', '产品开发者', '独立创业者'];
  let roleIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  const typewriter = document.getElementById('typewriter');

  function type() {
    const currentRole = roles[roleIndex];

    if (isDeleting) {
      typewriter.textContent = currentRole.substring(0, charIndex - 1);
      charIndex--;
    } else {
      typewriter.textContent = currentRole.substring(0, charIndex + 1);
      charIndex++;
    }

    let typeSpeed = isDeleting ? 50 : 100;

    if (!isDeleting && charIndex === currentRole.length) {
      typeSpeed = 2000;
      isDeleting = true;
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      roleIndex = (roleIndex + 1) % roles.length;
      typeSpeed = 500;
    }

    setTimeout(type, typeSpeed);
  }

  type();
</script>

<!-- Three.js 3D Scene -->
<script type="module">
  // Load Three.js from CDN
  import * as THREE from 'https://unpkg.com/three@0.160.0/build/three.module.js';

  // Check if container exists (desktop only)
  const container = document.getElementById('hero-3d-container');
  if (!container) {
    throw new Error('Container not found');
  }

  // Scene setup
  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(60, container.clientWidth / container.clientHeight, 0.1, 1000);
  camera.position.z = 5;

  const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
  renderer.setSize(container.clientWidth, container.clientHeight);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setClearColor(0x000000, 0);
  container.appendChild(renderer.domElement);

  // Teal color palette
  const tealMain = new THREE.Color(0x14b8a6);
  const tealLight = new THREE.Color(0x2dd4bf);
  const tealDark = new THREE.Color(0x0d9488);

  // Main icosahedron (center piece)
  const icoGeometry = new THREE.IcosahedronGeometry(1.2, 1);
  const icoMaterial = new THREE.MeshBasicMaterial({
    color: tealMain,
    wireframe: true,
    transparent: true,
    opacity: 0.4
  });
  const icosahedron = new THREE.Mesh(icoGeometry, icoMaterial);
  scene.add(icosahedron);

  // Inner icosahedron
  const innerIcoGeometry = new THREE.IcosahedronGeometry(0.8, 0);
  const innerIcoMaterial = new THREE.MeshBasicMaterial({
    color: tealLight,
    wireframe: true,
    transparent: true,
    opacity: 0.25
  });
  const innerIcosahedron = new THREE.Mesh(innerIcoGeometry, innerIcoMaterial);
  scene.add(innerIcosahedron);

  // Core sphere with glow effect
  const coreGeometry = new THREE.SphereGeometry(0.3, 16, 16);
  const coreMaterial = new THREE.MeshBasicMaterial({
    color: tealLight,
    transparent: true,
    opacity: 0.6
  });
  const core = new THREE.Mesh(coreGeometry, coreMaterial);
  scene.add(core);

  // Orbiting smaller shapes
  const orbitingShapes = [];
  const orbitRadii = [2.2, 2.8, 3.2];
  const orbitSpeeds = [0.3, 0.2, 0.15];
  const orbitOffsets = [0, Math.PI * 0.66, Math.PI * 1.33];

  for (let i = 0; i < 3; i++) {
    // Create different shapes
    let geometry;
    if (i === 0) {
      geometry = new THREE.OctahedronGeometry(0.15, 0);
    } else if (i === 1) {
      geometry = new THREE.TetrahedronGeometry(0.12, 0);
    } else {
      geometry = new THREE.BoxGeometry(0.12, 0.12, 0.12);
    }

    const material = new THREE.MeshBasicMaterial({
      color: tealMain,
      transparent: true,
      opacity: 0.5
    });
    const shape = new THREE.Mesh(geometry, material);
    orbitingShapes.push(shape);
    scene.add(shape);
  }

  // Particle stars
  const particlesCount = 150;
  const particlesGeometry = new THREE.BufferGeometry();
  const positions = new Float32Array(particlesCount * 3);

  for (let i = 0; i < particlesCount; i++) {
    const i3 = i * 3;
    const radius = 3 + Math.random() * 4;
    const theta = Math.random() * Math.PI * 2;
    const phi = Math.acos(2 * Math.random() - 1);

    positions[i3] = radius * Math.sin(phi) * Math.cos(theta);
    positions[i3 + 1] = radius * Math.sin(phi) * Math.sin(theta);
    positions[i3 + 2] = radius * Math.cos(phi);
  }

  particlesGeometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));

  const particlesMaterial = new THREE.PointsMaterial({
    color: tealLight,
    size: 0.03,
    transparent: true,
    opacity: 0.6,
    sizeAttenuation: true
  });

  const particles = new THREE.Points(particlesGeometry, particlesMaterial);
  scene.add(particles);

  // Mouse interaction
  let mouseX = 0;
  let mouseY = 0;
  let targetX = 0;
  let targetY = 0;

  document.addEventListener('mousemove', (event) => {
    mouseX = (event.clientX / window.innerWidth) * 2 - 1;
    mouseY = -(event.clientY / window.innerHeight) * 2 + 1;
  });

  // Animation loop
  let time = 0;

  function animate() {
    requestAnimationFrame(animate);
    time += 0.01;

    // Smooth mouse follow
    targetX += (mouseX - targetX) * 0.05;
    targetY += (mouseY - targetY) * 0.05;

    // Rotate main shapes
    icosahedron.rotation.x = time * 0.15 + targetY * 0.3;
    icosahedron.rotation.y = time * 0.1 + targetX * 0.3;

    innerIcosahedron.rotation.x = -time * 0.2 + targetY * 0.2;
    innerIcosahedron.rotation.y = -time * 0.15 + targetX * 0.2;

    core.rotation.y = time * 0.3;

    // Pulse core
    const pulse = 1 + Math.sin(time * 2) * 0.1;
    core.scale.set(pulse, pulse, pulse);

    // Orbit smaller shapes
    orbitingShapes.forEach((shape, i) => {
      const angle = time * orbitSpeeds[i] + orbitOffsets[i];
      const radius = orbitRadii[i];

      shape.position.x = Math.cos(angle) * radius;
      shape.position.y = Math.sin(angle * 0.5) * 0.5;
      shape.position.z = Math.sin(angle) * radius;

      shape.rotation.x = time * 0.5;
      shape.rotation.y = time * 0.3;
    });

    // Rotate particles slowly
    particles.rotation.y = time * 0.02;
    particles.rotation.x = time * 0.01;

    renderer.render(scene, camera);
  }

  animate();

  // Handle resize
  window.addEventListener('resize', () => {
    if (!container) return;
    camera.aspect = container.clientWidth / container.clientHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(container.clientWidth, container.clientHeight);
  });
</script>
