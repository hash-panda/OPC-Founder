---
// Header component with navigation
---

<header class="fixed top-0 left-0 right-0 w-full z-50 bg-slate-900/95 backdrop-blur-md border-b border-slate-800">
  <div class="container mx-auto px-6 flex justify-between items-center h-16">
    <a href="/" class="text-xl font-bold tracking-tight">
      <span class="text-orange-500">OPC</span>
      <span class="text-slate-300">FOUNDER</span>
    </a>
    <nav class="hidden md:flex items-center gap-8">
      <a href="/#projects" class="text-slate-400 hover:text-orange-500 transition-colors text-sm font-medium">
        项目
      </a>
      <a href="/#about" class="text-slate-400 hover:text-orange-500 transition-colors text-sm font-medium">
        关于
      </a>
      <a href="/blog" class="text-slate-400 hover:text-orange-500 transition-colors text-sm font-medium">
        文章
      </a>
    </nav>
    <!-- Mobile menu button -->
    <button class="md:hidden text-slate-400 hover:text-orange-500" aria-label="Menu">
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>
</header>
