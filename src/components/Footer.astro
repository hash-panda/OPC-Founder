---
// Footer component
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-950 text-slate-400 py-12 border-t border-slate-800">
  <div class="container mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-center gap-8">
      <!-- Logo & Tagline -->
      <div class="text-center md:text-left">
        <a href="/" class="text-xl font-bold tracking-tight">
          <span class="text-orange-500">OPC</span>
          <span class="text-slate-300">FOUNDER</span>
        </a>
        <p class="text-slate-500 text-sm mt-2">一个人的多元探索之旅</p>
      </div>

      <!-- Navigation -->
      <nav class="flex flex-wrap justify-center gap-6">
        <a href="#projects" class="text-slate-500 hover:text-orange-500 transition-colors text-sm">
          项目
        </a>
        <a href="#about" class="text-slate-500 hover:text-orange-500 transition-colors text-sm">
          关于
        </a>
        <a href="/blog" class="text-slate-500 hover:text-orange-500 transition-colors text-sm">
          文章
        </a>
      </nav>

      <!-- Social Links -->
      <div class="flex items-center gap-4">
        <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center hover:bg-orange-500 transition-colors group" aria-label="Twitter">
          <svg class="w-5 h-5 text-slate-400 group-hover:text-white" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center hover:bg-orange-500 transition-colors group" aria-label="GitHub">
          <svg class="w-5 h-5 text-slate-400 group-hover:text-white" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
          </svg>
        </a>
        <a href="mailto:hello@opcfounder.com" class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center hover:bg-orange-500 transition-colors group" aria-label="Email">
          <svg class="w-5 h-5 text-slate-400 group-hover:text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="M22 6l-10 7L2 6"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-12 pt-8 border-t border-slate-800 text-center">
      <p class="text-slate-600 text-sm">
        &copy; {currentYear} OPC Founder. All rights reserved.
      </p>
    </div>
  </div>
</footer>
