---
// Footer component
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-950 text-slate-400 py-12 border-t border-slate-800">
  <div class="container mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-center gap-8">
      <!-- Logo & Tagline -->
      <div class="text-center md:text-left">
        <a href="/" class="text-xl font-bold tracking-tight">
          <span class="text-orange-500">OPC</span>
          <span class="text-slate-300">FOUNDER</span>
        </a>
        <p class="text-slate-500 text-sm mt-2">一个人的多元探索之旅</p>
      </div>

      <!-- Navigation -->
      <nav class="flex flex-wrap justify-center gap-6">
        <a href="/#projects" class="text-slate-500 hover:text-orange-500 transition-colors text-sm">
          项目
        </a>
        <a href="/#about" class="text-slate-500 hover:text-orange-500 transition-colors text-sm">
          关于
        </a>
        <a href="/blog" class="text-slate-500 hover:text-orange-500 transition-colors text-sm">
          文章
        </a>
      </nav>

    </div>

    <!-- Copyright -->
    <div class="mt-12 pt-8 border-t border-slate-800 text-center">
      <p class="text-slate-600 text-sm">
        &copy; {currentYear} OPC Founder. All rights reserved.
      </p>
    </div>
  </div>
</footer>
